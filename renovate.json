{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "git-submodules": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchPackageNames": ["chicken"],
      "matchManagers": ["cargo"],
      "enabled": true,
      "automerge": false,
      "commitMessagePrefix": "chore(deps):",
      "prBodyNotes": ["📦 See [chicken release notes](https://github.com/timjonaswechler/chicken/releases) for full changelog."]
    }
  ]
}
